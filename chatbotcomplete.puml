@startuml Complete_Chatbot_Activity_Diagram

!theme plain
skinparam backgroundColor white
skinparam activityBorderThickness 2
skinparam activityBorderColor #888888
skinparam activityBackgroundColor #E0E0E0
skinparam arrowThickness 1.5
skinparam activityFontSize 10

title Activity Diagram

start

:User Opens Chatbot;

:Display Welcome Message;

:User Types Message;

:Validate Input;

if (Valid Input?) then (yes)
  :Send to Backend;
  
  :Preprocess Text;
  
  :NLP Analysis;
  
  :Identify Intent;
  
  :Extract Entities;
  
  if (Intent Recognized?) then (yes)
    :Query Database;
    
    if (Response Found?) then (yes)
      :Retrieve Response;
    else (no)
      :Generate Fallback Response;
    endif
    
  else (no)
    :Show Default Message;
  endif
  
  :Log Conversation;
  
  :Send Response to User;
  
  :Display Response;
  
  if (User Satisfied?) then (yes)
    :Log Positive Feedback;
  else (no)
    :Log Negative Feedback;
  endif
  
  if (Continue Chat?) then (yes)
    :User Types Message;
  else (no)
    :Save Session;
    :Display Goodbye;
    stop
  endif
  
else (no)
  :Show Error Message;
  stop
endif

@enduml